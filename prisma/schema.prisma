generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  FAILED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum BlockReason {
  BOOKING
  MAINTENANCE
  MANUAL
  EXTERNAL
}

enum BlockSource {
  INTERNAL
  EXTERNAL
}

// ─── Models ──────────────────────────────────────────────

model Villa {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?
  pricePerNight  Decimal  @map("price_per_night")
  maxGuests      Int      @map("max_guests")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  bookings              Booking[]
  availabilityBlocks    AvailabilityBlock[]
  externalCalendarFeeds ExternalCalendarFeed[]
  externalCalendarEvents ExternalCalendarEvent[]

  @@map("villas")
}

model Booking {
  id              String        @id @default(cuid())
  villaId         String        @map("villa_id")
  guestName       String        @map("guest_name")
  guestEmail      String        @map("guest_email")
  guestPhone      String?       @map("guest_phone")
  checkIn         DateTime      @map("check_in") @db.Date
  checkOut        DateTime      @map("check_out") @db.Date
  guestCount      Int           @map("guest_count")
  specialRequests String?       @map("special_requests")
  status          BookingStatus @default(DRAFT)
  totalAmount     Decimal       @map("total_amount")
  currency        String        @default("USD")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  villa              Villa              @relation(fields: [villaId], references: [id])
  payments           Payment[]
  availabilityBlock  AvailabilityBlock?

  @@map("bookings")
}

model AvailabilityBlock {
  id        String      @id @default(cuid())
  villaId   String      @map("villa_id")
  startDate DateTime    @map("start_date") @db.Date
  endDate   DateTime    @map("end_date") @db.Date
  reason    BlockReason
  source    BlockSource @default(INTERNAL)
  bookingId String?     @unique @map("booking_id")
  createdAt DateTime    @default(now()) @map("created_at")

  villa   Villa    @relation(fields: [villaId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@map("availability_blocks")
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String        @map("booking_id")
  provider              String        @default("FAC")
  amount                Decimal
  currency              String        @default("USD")
  status                PaymentStatus @default(PENDING)
  externalTransactionId String?       @map("external_transaction_id")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model ExternalCalendarFeed {
  id           String    @id @default(cuid())
  villaId      String    @map("villa_id")
  sourceName   String    @map("source_name")
  feedUrl      String    @map("feed_url")
  isActive     Boolean   @default(true) @map("is_active")
  lastSyncedAt DateTime? @map("last_synced_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  villa  Villa                   @relation(fields: [villaId], references: [id])
  events ExternalCalendarEvent[]

  @@map("external_calendar_feeds")
}

model ExternalCalendarEvent {
  id               String   @id @default(cuid())
  villaId          String   @map("villa_id")
  externalFeedId   String   @map("external_feed_id")
  externalEventUid String   @map("external_event_uid")
  startDate        DateTime @map("start_date") @db.Date
  endDate          DateTime @map("end_date") @db.Date
  summary          String?
  rawPayload       String?  @map("raw_payload")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  villa Villa                @relation(fields: [villaId], references: [id])
  feed  ExternalCalendarFeed @relation(fields: [externalFeedId], references: [id])

  @@unique([externalFeedId, externalEventUid])
  @@map("external_calendar_events")
}
